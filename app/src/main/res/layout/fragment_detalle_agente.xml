<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/valorant_dark">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/valorant_card">

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/imgDetailAgent"
                    android:layout_width="180dp"
                    android:layout_height="180dp"/>

                <TextView
                    android:id="@+id/tvDetailAgentNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#01"
                    android:textColor="@color/valorant_gray"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvDetailAgentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jett"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvDetailAgentRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duelista"
                    android:textStyle="bold"
                    android:textColor="@color/valorant_red"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvDetailAgentDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción del agente..."
                    android:textColor="@color/valorant_gray"
                    android:layout_marginTop="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <TextView
                        android:text="Habilidades"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvSkillE"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@color/valorant_card"
                        android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvSkillQ"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@color/valorant_card"
                        android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvSkillC"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@color/valorant_card"
                        android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvSkillX"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@color/valorant_card"
                        android:textColor="@color/white"
                        android:layout_marginBottom="16dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
